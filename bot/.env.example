# iSales Support Bot v5.2 — Widget Edition

# Google Sheets
GOOGLE_SPREADSHEET_ID=ваш_id_таблицы
GOOGLE_CREDENTIALS_CONTENT={ весь json одной строкой }

# ── AI: выбор бэкенда ─────────────────────────────────────────────
USE_AI=0               # 1 = включить AI-поиск, 0 = только keyword

# Бэкенд (выбрать один):
USE_DEEPSEEK=0         # 1 = OpenRouter/DeepSeek (бесплатно)
                       # 0 = Anthropic Claude Haiku (платно, ~$0.0004/вопрос)

# Anthropic (нужен если USE_DEEPSEEK=0)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (нужен если USE_DEEPSEEK=1)
# Получить ключ: https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-...

# Общие AI-настройки
FAQ_CACHE_TTL_HOURS=6
MAX_CLARIFY_ATTEMPTS=3

# ── Панель поддержки ──────────────────────────────────────────────
SUPPORT_PASSWORD=ваш_пароль

# ── Макс (закомментировано, не актуально) ─────────────────────────
# MAX_BOT_TOKEN=
# MAX_API_BASE=https://platform-api.max.ru
# WEBHOOK_URL=
# SUPPORT_USER_ID=
